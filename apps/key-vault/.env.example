# Key Vault Configuration
# ⚠️ NEVER COMMIT REAL VALUES

# Server
KEY_VAULT_PORT=4000

# Master encryption key (256-bit hex - generate with: openssl rand -hex 32)
KEY_VAULT_MASTER_KEY=your-64-character-hex-key-here-generate-with-openssl-rand-hex-32

# JWT secret for service auth (generate with: openssl rand -hex 32)
KEY_VAULT_JWT_SECRET=your-jwt-secret-here-generate-with-openssl-rand-hex-32

# Database path
KEY_VAULT_DB_PATH=./data/vault.db

# Allowed origins (comma-separated)
KEY_VAULT_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
