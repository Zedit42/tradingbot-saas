generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

// ============================================================================
// AUTH (NextAuth)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  
  // Subscription
  plan          String    @default("free") // free, pro, elite
  stripeCustomerId String?
  stripeSubscriptionId String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  wallets       Wallet[]
  bots          Bot[]
  trades        Trade[]
  alerts        Alert[]
  profile       UserProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// WALLETS
// ============================================================================

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  address   String
  chain     String   // evm, solana
  label     String?
  
  // Encrypted private key (optional - for managed wallets)
  encryptedKey String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bots      Bot[]
  trades    Trade[]
  
  @@unique([userId, address])
}

// ============================================================================
// BOTS
// ============================================================================

model Bot {
  id        String   @id @default(cuid())
  userId    String
  walletId  String
  
  type      String   // polymarket, hyperliquid, solana, grid, dca, funding, whale
  name      String
  status    String   @default("stopped") // stopped, running, paused
  
  // Bot config (JSON)
  config    String   @default("{}")
  
  // Stats
  totalTrades   Int      @default(0)
  totalPnl      Float    @default(0)
  winRate       Float    @default(0)
  
  lastRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  trades    Trade[]
}

// ============================================================================
// TRADES
// ============================================================================

model Trade {
  id        String   @id @default(cuid())
  userId    String
  walletId  String
  botId     String?
  
  type      String   // buy, sell, long, short
  market    String   // BTC-PERP, polymarket-slug, etc.
  amount    Float
  price     Float
  
  pnl       Float?
  status    String   @default("pending") // pending, filled, cancelled
  
  txHash    String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  bot       Bot?     @relation(fields: [botId], references: [id], onDelete: SetNull)
}

// ============================================================================
// PRICE ALERTS
// ============================================================================

model Alert {
  id        String   @id @default(cuid())
  userId    String
  
  coin      String   // BTC, ETH, SOL, etc.
  condition String   // above, below
  price     Float    // Target price
  
  // Notification channels
  notifyTelegram Boolean @default(true)
  notifyEmail    Boolean @default(false)
  
  triggered   Boolean  @default(false)
  triggeredAt DateTime?
  
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================================
// WAITLIST
// ============================================================================

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  
  // Referral tracking
  referralCode  String   @unique @default(cuid())
  referredBy    String?  // referralCode of referrer
  referralCount Int      @default(0)
  
  // Priority (higher = earlier access)
  priority   Int      @default(0)
  
  // Status
  status     String   @default("waiting") // waiting, invited, converted
  invitedAt  DateTime?
  convertedAt DateTime?
  
  // Metadata
  source     String?  // landing, twitter, producthunt, etc.
  ipAddress  String?
  userAgent  String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================================
// USER PROFILE (Leaderboard & Telegram)
// ============================================================================

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  
  // Display
  displayName   String?
  avatarUrl     String?
  isPublic      Boolean @default(true)  // Show on leaderboard
  
  // Telegram Integration
  telegramId    String?  @unique
  telegramUsername String?
  telegramVerified Boolean @default(false)
  
  // Leaderboard Stats (cached)
  totalPnl      Float   @default(0)
  totalTrades   Int     @default(0)
  winRate       Float   @default(0)
  rank          Int?
  
  // Streak & Achievements
  currentStreak Int     @default(0)
  bestStreak    Int     @default(0)
  badges        String  @default("[]") // JSON array of badge IDs
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
